# Backend API Port
PORT=3001

# Supabase PostgreSQL Database URL
DATABASE_URL="postgresql://postgres:password@db.your-id.supabase.co:5432/postgres"

# Gemini inference API key
GEMINI_API_KEY="your_gemini_api_key"

# Pinecone API Key and Host URL
PINECONE_API_KEY="pcsk_your_pinecone_key"
PINECONE_INDEX_HOST="https://your-index-host.pinecone.io"

# CORS Origin (Frontend URL)
CORS_ORIGIN="http://localhost:5173"